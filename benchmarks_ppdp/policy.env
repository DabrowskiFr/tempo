# Benchmark safety policy (shared defaults for the whole pack).
#
# Canonical baseline for "before/after" comparisons:
CANONICAL_BASELINE_ID="v0.2.0"
CANONICAL_BASELINE_COMMIT="003539d"

# Very old baseline kept for archaeology only.
LEGACY_BASELINE_ID="preopt-legacy"
LEGACY_BASELINE_COMMIT="f99778b"
ALLOW_LEGACY_BASELINE=0

# Guard against accidentally launching very expensive campaigns.
MAX_REASONABLE_SIZE=5000
ALLOW_LARGE_N=0
