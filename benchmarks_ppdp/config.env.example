# Optional fallback path: local Tempo repo used to pin/install package if missing.
# For this repository layout, benchmarks_ppdp lives under tempo-dev, so ".." points to repo root.
TEMPO_REPO=".."

# Switches (kept fixed for parity with the paper campaign).
TEMPO_SWITCH="5.4.1+options"
RML_SWITCH="rml-4.14"

# Repetitions.
RUNS=10

# Size grid (space-separated). You can override per benchmark below.
SIZES="10 100 1000 2000 3000 5000 7000 10000"
SIZES_PROPAGATION_CHAINS="10 100 1000 2000 3000 5000 7000 10000"
SIZES_BROADCAST_EXPANSION="10 100 1000 2000 3000 5000 7000 10000"
# Fork explosion: use sizes that map to distinct depths.
SIZES_FORK_EXPLOSION="10 100 1000 2000 3000 5000 9000 17000"
SIZES_GUARDED_CASCADES="10 100 1000 2000 3000 5000 7000 10000"
SIZES_NESTED_PREEMPTION="10 100 1000 2000 3000 5000 7000 10000"

# Benchmark list.
BENCHMARKS="propagation_chains broadcast_expansion fork_explosion guarded_cascades nested_preemption"

# Frozen reference pair used by scripts/summarize_reference.py and scripts/plot_reference.py.
REFERENCE_TEMPO_CSV="tempo-reference-good.csv"
REFERENCE_RML_CSV="rml-reference-good.csv"
