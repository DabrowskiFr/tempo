# Optional fallback path: local Tempo repo used to pin/install package if missing.
# For this repository layout, benchmarks_ppdp lives under tempo-dev, so ".." points to repo root.
TEMPO_REPO=".."

# Switches (kept fixed for parity with the paper campaign).
TEMPO_SWITCH="5.4.1+options"
RML_SWITCH="rml-4.14"

# Optional second ReactiveML target on OCaml 5 (disabled by default).
# When enabled, run_all.sh also runs scripts/run_rml_ocaml5.sh.
RML_OCAML5_ENABLED=0
RML_OCAML5_SWITCH="$TEMPO_SWITCH"
RML_OCAML5_IMPL="rml_ocaml5"
RML_OCAML5_RUN_NAME="rml_ocaml5"
# Optional: explicit patched compiler path (if rmlc is not installed in RML_OCAML5_SWITCH).
# RML_OCAML5_RMLC="/absolute/path/to/rml-1.09.07-2021-07-26-ocaml-5/compiler/rmlc"
# Optional: explicit ReactiveML stdlib/runtime root seen by rmlc as RMLLIB.
# RML_OCAML5_RMLLIB="/absolute/path/to/rml/lib/lco"

# Repetitions.
RUNS=10

# Safety guard from policy.env: with ALLOW_LARGE_N=0, sizes above MAX_REASONABLE_SIZE
# are refused. Set to 1 only for explicit stress campaigns.
ALLOW_LARGE_N=0

# Size grid (space-separated). This default is the paper-friendly bounded grid.
# For >5000 stress runs, set ALLOW_LARGE_N=1 explicitly.
SIZES="10 100 1000 5000"
SIZES_PROPAGATION_CHAINS="10 100 1000 5000"
SIZES_BROADCAST_EXPANSION="10 100 1000 5000"
SIZES_FORK_EXPLOSION="10 100 1000 5000"
SIZES_GUARDED_CASCADES="10 100 1000 5000"
SIZES_NESTED_PREEMPTION="10 100 1000 5000"

# Benchmark list.
BENCHMARKS="propagation_chains broadcast_expansion fork_explosion guarded_cascades nested_preemption"

# Frozen reference pair used by scripts/summarize_reference.py and scripts/plot_reference.py.
REFERENCE_TEMPO_CSV="tempo-reference-good.csv"
REFERENCE_RML_CSV="rml-reference-good.csv"
