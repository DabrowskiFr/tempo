#!/bin/sh
set -eu

if [ "${1:-}" = "" ] || [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOT'
Usage:
  dune exec ./applications/reconfiguration/run -- <app> [-- <args...>]

Apps (compat):
  (removed) reactive-reconfiguration-engine
  (removed) refactor
EOT
  exit 0
fi

APP="$1"
shift

echo "This launcher is deprecated: refactor was removed from the repository." >&2
echo "Use: dune exec ./applications/run -- help" >&2
exit 2
