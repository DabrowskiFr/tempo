bug-reports: "https://github.com/DabrowskiFr/tempo/issues"
depends: [
  "ocaml" {>= "5.3.0"}
  "dune" {>= "3.19" & >= "3.0"}
  "tempo-fluidsynth" {= version}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/DabrowskiFr/tempo.git"
